---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import Projects from "../components/Projects.astro";
---

<Layout>
  <Hero />

 <section id="sobre-mi" class="section">
  <h2>Sobre mí</h2>

  <p>
    Entusiasta de la ciberseguridad enfocado en pentesting web, análisis de vulnerabilidades y fundamentos de redes.
  </p>

  <p>
    Actualmente en formación activa mediante laboratorios, CTFs y entornos controlados.
  </p>

  <ul class="about-list">
    <li><span class="tag">Interés:</span> Red Team / Pentesting</li>
    <li><span class="tag">Enfoque:</span> OWASP Top 10</li>
    <li><span class="tag">Práctica:</span> Hackthebox + Labs locales</li>
    <li><span class="tag">Objetivo:</span> Rol junior en ciberseguridad</li>
  </ul>
</section>

  <section id="progreso" class="section">
  <h2>Progreso</h2>

  <div class="grid">

    <div class="card">
      <h3>Pentesting Web</h3>
      <p>Aprendizaje activo de OWASP Top 10 y explotación básica.</p>
      <p class="muted">Nivel: en progreso</p>
    </div>

    <div class="card">
      <h3>Redes</h3>
      <p>Fundamentos de TCP/IP, DNS, HTTP y análisis de tráfico.</p>
      <p class="muted">Nivel: intermedio</p>
    </div>

    <div class="card">
      <h3>Linux</h3>
      <p>Uso diario en entornos de pentesting y administración básica.</p>
      <p class="muted">Nivel: intermedio</p>
    </div>

    <div class="card">
      <h3>Python</h3>
      <p>Automatización de tareas y scripting aplicado a seguridad.</p>
      <p class="muted">Nivel: medio</p>
    </div>

    <div class="card">
      <h3>Docker</h3>
      <p>Contenerización de entornos de práctica y despliegue de servicios.</p>
      <p class="muted">Nivel: avanzado</p>
    </div>

  </div>
</section>

<section id="github" class="section">
  <h2>GitHub</h2>

  <p>
    Desarrollo y documentación de proyectos de aprendizaje en ciberseguridad.
  </p>

  <a class="mail-link" href="https://github.com/marcoscarmonagarcia" target="_blank">
    ver repositorios →
  </a>
</section>

  <section id="habilidades" class="section">
    <h2>Habilidades</h2>
    <p>Linux · Redes · Seguridad Web · Python · Docker · Bash · Burp Suite · Docker </p>
  </section>

  <Projects />

 <section id="labs" class="section">
  <p class="muted">
  Actualización constante basada en práctica diaria y resolución de escenarios reales.
</p>
<br>
  <h2>Labs / CTFs</h2>

  <p>
    Práctica continua en entornos controlados para desarrollo de habilidades ofensivas.
  </p>
  

  <div class="grid">

 <article class="card">
  <h3>Hack The Box - Tiers completados</h3>
  <p>
    Resolución de máquinas y retos en Hack The Box con enfoque en enumeración, explotación y escalada de privilegios.
  </p>

  <p class="muted">
    Progreso: Tiers básicos completados
  </p>

  <div class="tags">
    <span>HackTheBox</span>
    <span>Linux</span>
    <span>Privilege Escalation</span>
    <span>Enumeration</span>
  </div>
</article>

    <article class="card">
      <h3>OWASP Juice Shop</h3>
      <p>
        Prácticas en vulnerabilidades web reales: XSS, SQLi, IDOR y control de acceso.
      </p>

      <div class="tags">
        <span>Web Security</span>
        <span>OWASP Top 10</span>
        <span>Burp Suite</span>
      </div>
    </article>

    <article class="card">
      <h3>Home Lab (Local)</h3>
      <p>
        Entorno local de pruebas con máquinas virtuales para simulación de ataques básicos.
      </p>

      <div class="tags">
        <span>Kali Linux</span>
        <span>VMs</span>
        <span>Active Recon</span>
      </div>
    </article>

  </div>
</section>
<section id="blog" class="section">
  <h2>Blog técnico</h2>

  <p>
    Writeups y notas técnicas sobre ciberseguridad, CTFs y vulnerabilidades web.
  </p>

  <a class="mail-link" href={`${import.meta.env.BASE_URL}blog`}>
    ver todos los writeups →
  </a>
</section>
  <section id="contacto" class="section">
    <h2>Contacto</h2>

    <div class="terminal-contact">
      <p><span class="prompt">></span> contacto --email</p>

      <p>
        maervca2 [at] icloud [dot] com
      </p>

      <p><span class="prompt">></span> acción</p>

      <a class="mail-link" href="mailto:maervca2@icloud.com">
        enviar email seguro →
      </a>
    </div>
  </section>
</Layout>