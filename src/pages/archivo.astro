---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog")).sort(
  (a, b) =>
    new Date(b.data.date).getTime() -
    new Date(a.data.date).getTime()
);

const archiveItems = posts.map((post) => {
  const searchableText = [
    post.data.title,
    post.data.description,
    ...(post.data.tags ?? []),
  ]
    .filter(Boolean)
    .join(" ")
    .toLowerCase();

  return { ...post, searchableText };
});
---

<Layout>
  <section class="section">
    <h2>Archivo de publicaciones</h2>

    <div class="blog-controls">
      <input id="search" type="text" placeholder="Buscar posts..." />
      <span class="count" id="count">{archiveItems.length} artículos</span>
    </div>

    <ul class="archive-list" id="archive-list">
      {archiveItems.map((post) => (
        <li class="archive-item" data-search={post.searchableText}>
          <span class="date">
            {new Date(post.data.date).toLocaleDateString("es-ES")}
          </span>

          <a href={`/blog/${post.id}`}>
            {post.data.title}
          </a>
        </li>
      ))}
    </ul>

    <p id="empty" style="display:none;">No hay resultados</p>
  </section>

  <script is:inline>
    const input = document.getElementById("search");
    const items = Array.from(document.querySelectorAll(".archive-item"));
    const empty = document.getElementById("empty");
    const count = document.getElementById("count");

    const updateResults = () => {
      const value = input.value.trim().toLowerCase();
      let visible = 0;

      items.forEach((item) => {
        const match = item.dataset.search.includes(value);
        item.style.display = match ? "flex" : "none";
        if (match) visible++;
      });

      empty.style.display = visible === 0 ? "block" : "none";
      count.textContent = `${visible} ${visible === 1 ? "artículo" : "artículos"}`;
    };

    input.addEventListener("input", updateResults);
    updateResults();
  </script>
</Layout>