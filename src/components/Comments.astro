---
interface Props {
  title: string;
  slug: string;
}

const { title, slug } = Astro.props;

const giscusRepo = import.meta.env.PUBLIC_GISCUS_REPO ?? "MarcosCarmonaGarcia/marcos-portfolio";
const giscusRepoId = import.meta.env.PUBLIC_GISCUS_REPO_ID ?? "R_kgDOTJ8h8w";
const giscusCategory = import.meta.env.PUBLIC_GISCUS_CATEGORY ?? "Comentarios";
const giscusCategoryId = import.meta.env.PUBLIC_GISCUS_CATEGORY_ID ?? "DIC_kwDOTJ8h884DATbk";
const giscusTheme = import.meta.env.PUBLIC_GISCUS_THEME ?? "dark";
const giscusLang = import.meta.env.PUBLIC_GISCUS_LANG ?? "es";
const discussionTerm = `blog/${slug}`;
---

<div class="comments-section">
  <script
    src="https://giscus.app/client.js"
    data-repo={giscusRepo}
    data-repo-id={giscusRepoId}
    data-category={giscusCategory}
    data-category-id={giscusCategoryId}
    data-mapping="specific"
    data-term={discussionTerm}
    data-title={title}
    data-strict="0"
    data-reactions-enabled="1"
    data-emit-metadata="0"
    data-input-position="bottom"
    data-theme={giscusTheme}
    data-lang={giscusLang}
    data-loading="lazy"
    crossorigin="anonymous"
    async
  ></script>
</div>

<style>
  .comments-section {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid #1f2937;
  }
</style>
