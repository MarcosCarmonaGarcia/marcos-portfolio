---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog")).sort(
  (a, b) =>
    new Date(b.data.date).getTime() -
    new Date(a.data.date).getTime()
);
---

<Layout>
  <section class="section">
    <h2>Blog técnico</h2>

    <div class="blog-controls">
      <input id="search" type="text" placeholder="Buscar posts..." />
      <span class="count">{posts.length} posts</span>
    </div>

    <div class="grid" id="posts">
      {posts.map((post) => (
        <article class="card post-card">
          <h3>{post.data.title}</h3>
          <p>{post.data.description}</p>

          {post.data.tags && post.data.tags.length > 0 && (
            <div class="tags">
              {post.data.tags.map((tag) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
          )}

          <div class="meta">
            <span>{new Date(post.data.date).toLocaleDateString()}</span>
          </div>

          <a class="mail-link" href={`${import.meta.env.BASE_URL}blog/${post.id}`}>
            leer post →
          </a>
        </article>
      ))}
    </div>

    <p id="empty" style="display:none;">No hay resultados</p>
  </section>

  <script is:inline>
    const input = document.getElementById("search");
    const cards = document.querySelectorAll(".post-card");
    const empty = document.getElementById("empty");

    input.addEventListener("input", (e) => {
      const value = e.target.value.toLowerCase();
      let visible = 0;

      cards.forEach((card) => {
        const match = card.innerText.toLowerCase().includes(value);
        card.style.display = match ? "block" : "none";
        if (match) visible++;
      });

      empty.style.display = visible === 0 ? "block" : "none";
    });
  </script>
</Layout>