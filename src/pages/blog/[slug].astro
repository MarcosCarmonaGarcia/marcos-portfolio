---
import Layout from "../../layouts/Layout.astro";
import { getCollection, render } from "astro:content";
import Comments from "../../components/Comments.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog");

  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const postUrl = new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin).toString();
const shareText = `${post.data.title} — ${post.data.description}`;
const encodedPostUrl = encodeURIComponent(postUrl);
const encodedShareText = encodeURIComponent(shareText);

const posts = await getCollection("blog");
const currentIndex = posts.findIndex((p) => p.id === post.id);

const prev = posts[currentIndex - 1];
const next = posts[currentIndex + 1];
---

<Layout>
  <article class="section post-article">
    <h1>{post.data.title}</h1>
    <p class="meta">{post.data.description}</p>

    {post.data.tags && post.data.tags.length > 0 && (
      <div class="tags">
        {post.data.tags.map((tag) => (
          <span class="tag">{tag}</span>
        ))}
      </div>
    )}

    <hr />

    <Content />

    <section class="share-section" aria-labelledby="share-post">
      <h2 id="share-post">Compartir en redes</h2>
      <p>Si te resultó útil, compártelo para que más gente lo vea.</p>

      <div class="share-actions">
        <a
          class="share-btn"
          href={`https://twitter.com/intent/tweet?url=${encodedPostUrl}&text=${encodedShareText}`}
          target="_blank"
          rel="noopener noreferrer"
        >
          X / Twitter
        </a>

        <a
          class="share-btn"
          href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodedPostUrl}`}
          target="_blank"
          rel="noopener noreferrer"
        >
          LinkedIn
        </a>

        <a
          class="share-btn"
          href={`https://api.whatsapp.com/send?text=${encodedShareText}%20${encodedPostUrl}`}
          target="_blank"
          rel="noopener noreferrer"
        >
          WhatsApp
        </a>

        <a
          class="share-btn"
          href={`https://www.facebook.com/sharer/sharer.php?u=${encodedPostUrl}`}
          target="_blank"
          rel="noopener noreferrer"
        >
          Facebook
        </a>

        <button type="button" class="share-btn share-copy" data-copy-link data-copy-url={postUrl}>
          Copiar enlace
        </button>
      </div>
    </section>

    <Comments title={post.data.title} slug={post.id} />

    <div class="post-nav">
      {prev && (
        <a href={`${import.meta.env.BASE_URL}blog/${prev.id}`} class="nav-btn">
          ← Anterior
        </a>
      )}

      {next && (
        <a href={`${import.meta.env.BASE_URL}blog/${next.id}`} class="nav-btn">
          Siguiente →
        </a>
      )}
    </div>
  </article>

  <div class="image-lightbox" id="imageLightbox" hidden aria-hidden="true">
    <button type="button" class="lightbox-close" aria-label="Cerrar imagen ampliada">
      ×
    </button>
    <img id="lightboxImage" alt="Imagen ampliada" />
  </div>

  <script is:inline>
    window.addEventListener("DOMContentLoaded", () => {
      const blocks = document.querySelectorAll(".post-article pre");

      blocks.forEach((block) => {
        const code = block.querySelector("code");
        const preClasses = block.className || "";
        const codeClasses = code?.className || "";

        let lang =
          block.getAttribute("data-language") ||
          block.getAttribute("data-lang") ||
          "";

        if (!lang) {
          const source = `${preClasses} ${codeClasses}`;
          const match = source.match(/language-([a-zA-Z0-9_+-]+)/);
          lang = match?.[1] || "text";
        }

        block.setAttribute("data-code-lang", lang.toUpperCase());
      });

      const imageLinks = Array.from(document.querySelectorAll(".post-article a")).filter(
        (link) => link.querySelector("img")
      );

      const lightbox = document.getElementById("imageLightbox");
      const lightboxImage = document.getElementById("lightboxImage");
      const closeButton = lightbox?.querySelector(".lightbox-close");

      const closeLightbox = () => {
        if (!lightbox || !lightboxImage) return;
        lightbox.hidden = true;
        lightbox.setAttribute("aria-hidden", "true");
        lightboxImage.removeAttribute("src");
        document.body.classList.remove("lightbox-open");
      };

      imageLinks.forEach((link) => {
        link.addEventListener("click", (event) => {
          event.preventDefault();
          if (!lightbox || !lightboxImage) return;

          const preview = link.querySelector("img");
          const src = link.getAttribute("href") || preview?.getAttribute("src");
          if (!src) return;

          lightboxImage.setAttribute("src", src);
          lightboxImage.setAttribute("alt", preview?.getAttribute("alt") || "Imagen ampliada");
          lightbox.hidden = false;
          lightbox.setAttribute("aria-hidden", "false");
          document.body.classList.add("lightbox-open");
        });
      });

      closeButton?.addEventListener("click", closeLightbox);

      lightbox?.addEventListener("click", (event) => {
        if (event.target === lightbox) closeLightbox();
      });

      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape" && lightbox && !lightbox.hidden) {
          closeLightbox();
        }
      });

      const copyButton = document.querySelector("[data-copy-link]");

      copyButton?.addEventListener("click", async () => {
        const url = copyButton.getAttribute("data-copy-url") || window.location.href;

        try {
          await navigator.clipboard.writeText(url);
          copyButton.textContent = "Enlace copiado";
        } catch {
          copyButton.textContent = "No se pudo copiar";
        }

        window.setTimeout(() => {
          copyButton.textContent = "Copiar enlace";
        }, 1800);
      });
    });
  </script>
</Layout>